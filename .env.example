# ══════════════════════════════════════════════════════
#  goshs Docker Compose 설정
#  이 파일을 .env 로 복사하고 원하는 값으로 수정하세요.
#  cp .env.example .env
# ══════════════════════════════════════════════════════

# ── 기본 설정 ──────────────────────────────────────────
# goshs 서비스 포트 (브라우저에서 http://호스트IP:포트 로 접근)
GOSHS_PORT=8000

# 공유할 호스트 디렉토리 경로 (절대 경로 또는 상대 경로)
# 예: /mnt/nas/files  또는  ./shared
GOSHS_SHARE_DIR=./shared

# ── 인증 (Basic Auth) ──────────────────────────────────
# true: username/password 로 접근 제한
# false: 인증 없이 누구나 접근 가능
GOSHS_AUTH_ENABLED=false

# 인증 사용자 이름 (GOSHS_AUTH_ENABLED=true 일 때만 사용)
GOSHS_AUTH_USERNAME=admin

# 인증 비밀번호 (GOSHS_AUTH_ENABLED=true 일 때만 사용)
# 보안 강화: 컨테이너 내부에서 goshs -H 로 해시 생성 후 사용
# docker exec goshs goshs -H
GOSHS_AUTH_PASSWORD=changeme

# ── HTTPS/TLS ──────────────────────────────────────────
# true: HTTPS 활성화 (아래 GOSHS_TLS_MODE 로 방식 선택)
# false: HTTP로 동작
# 주의: true 이면 브라우저에서 https://로 접근해야 합니다
GOSHS_TLS_ENABLED=false

# TLS 인증서 발급 방식 (GOSHS_TLS_ENABLED=true 일 때만 사용)
# self-signed : 자체 서명 인증서 (기본, 브라우저 경고 발생)
# letsencrypt : Let's Encrypt 자동 발급 (공인 도메인 + 80/443 포트 필요)
# custom      : 직접 발급한 cert/key 파일 사용 (./certs/ 에 배치)
GOSHS_TLS_MODE=self-signed

# letsencrypt 모드 전용 — 공인 도메인이 있어야 발급 가능
# 80/443 포트를 열려면: docker compose -f docker-compose.yml -f docker-compose.letsencrypt.yml up -d
# GOSHS_TLS_DOMAIN=home.example.com
# GOSHS_TLS_EMAIL=you@example.com

# custom 모드 전용 — ./certs/ 에 cert.pem / key.pem 을 배치 후 사용
# 볼륨 마운트를 열려면: docker compose -f docker-compose.yml -f docker-compose.custom-tls.yml up -d
# GOSHS_TLS_CERT_FILE=/certs/cert.pem
# GOSHS_TLS_KEY_FILE=/certs/key.pem

# ── 파일 업로드 ────────────────────────────────────────
# true: 브라우저에서 파일 업로드 허용 (GOSHS_SHARE_DIR 에 저장)
# false: 다운로드 전용 (파일 목록 조회 및 다운로드만 가능)
GOSHS_UPLOAD_ENABLED=false

# ── 클립보드 공유 ──────────────────────────────────────
# true: 웹소켓으로 모든 접속자 간 클립보드 공유 활성화
# false: 클립보드 기능 비활성화
GOSHS_CLIPBOARD_ENABLED=true
